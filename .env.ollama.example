ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chatbot_db
DATABASE_POOL_SIZE=20
DATABASE_ECHO=false

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# AWS Configuration (optional, only for S3 storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=chatbot-documents
SQS_QUEUE_URL=

# JWT Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration (optional)
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@chatbot.com

# Double Check (fact verification)
DOUBLE_CHECK_ENABLED=true
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage Provider (local or s3)
STORAGE_PROVIDER=local
STORAGE_PATH=./data/uploads

# Queue Provider
QUEUE_PROVIDER=redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM Provider - Ollama Configuration
LLM_PROVIDER=ollama

# Ollama API Configuration (cloud or local)
# For cloud: https://api.ollama.com
# For local: http://host.docker.internal:11434
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_MODEL=gpt-oss:120b-cloud

# Embedding Configuration
# EMBEDDING_PROVIDER can be: auto, ollama, openai, openai_like
# If set to "auto", it will follow LLM_PROVIDER or use OpenAI if OPENAI_EMBEDDING_MODEL is set
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=qwen3-embedding:4b

# Vector Store Configuration
QDRANT_URL=http://qdrant:6333

# OCR Configuration
# OCR_PROVIDER can be: pypdf2, llm
OCR_PROVIDER=pypdf2
# If OCR_PROVIDER=llm, set OCR_LLM_PROVIDER to: openai, anthropic, google, ollama, openai_like
OCR_LLM_PROVIDER=ollama

# Parallel Processing Configuration
OCR_PARALLEL=false
DOCUMENTS_PARALLEL=false
OCR_MAX_CONCURRENCY=3
DOCUMENTS_MAX_CONCURRENCY=2
OCR_MAX_RETRIES=3
DOCUMENTS_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=text

# CloudWatch Logging (optional, AWS only)
CLOUDWATCH_LOGGING_ENABLED=false
CLOUDWATCH_LOG_GROUP=/chatbot/backend
CLOUDWATCH_LOG_STREAM=backend

# Datadog Monitoring (optional)
DATADOG_API_KEY=
SERVICE_NAME=chatbot-backend

# Sentry Error Tracking (optional)
SENTRY_DSN=
