ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chatbot_db
DATABASE_POOL_SIZE=20
DATABASE_ECHO=false

REDIS_URL=redis://redis:6379/0

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=chatbot-documents
SQS_QUEUE_URL=

JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@chatbot.com

DOUBLE_CHECK_ENABLED=true
VERIFICATION_TOKEN_EXPIRE_HOURS=24

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

STORAGE_PROVIDER=local
STORAGE_PATH=./data/uploads

QUEUE_PROVIDER=redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b-cloud
EMBEDDING_MODEL=qwen3-embedding:4b
QDRANT_URL=http://qdrant:6333

OCR_PARALLEL=false
DOCUMENTS_PARALLEL=false
OCR_MAX_CONCURRENCY=3
DOCUMENTS_MAX_CONCURRENCY=2
OCR_MAX_RETRIES=3
DOCUMENTS_MAX_RETRIES=3

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=text

CLOUDWATCH_LOGGING_ENABLED=false
CLOUDWATCH_LOG_GROUP=/chatbot/backend
CLOUDWATCH_LOG_STREAM=backend

DATADOG_API_KEY=
SERVICE_NAME=chatbot-backend

SENTRY_DSN=
