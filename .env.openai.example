ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chatbot_db
DATABASE_POOL_SIZE=20
DATABASE_ECHO=false

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# AWS Configuration (optional, only for S3 storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=chatbot-documents
SQS_QUEUE_URL=

# JWT Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration (optional)
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@chatbot.com

# Double Check (fact verification)
DOUBLE_CHECK_ENABLED=true
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage Provider (local or s3)
STORAGE_PROVIDER=local
STORAGE_PATH=./data/uploads

# Queue Provider
QUEUE_PROVIDER=redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM Provider - OpenAI Configuration
LLM_PROVIDER=openai

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI Models Configuration
# Main LLM Model (for chat responses)
OPENAI_MODEL=gpt-4o

# Embedding Model (for vector search)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OCR Model (for document processing)
OPENAI_OCR_MODEL=gpt-4o-mini

# Optional: Uncomment to use GPT-4 Turbo (cheaper but slightly less capable)
# OPENAI_MODEL=gpt-4-turbo-preview

# Optional: Uncomment to use GPT-3.5 Turbo (much cheaper, faster, but less capable)
# OPENAI_MODEL=gpt-3.5-turbo

# Optional: Use larger embedding model (better quality but more expensive)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Embedding Configuration
# EMBEDDING_PROVIDER can be: auto, ollama, openai, openai_like
# If set to "auto", it will use OpenAI embeddings when OPENAI_EMBEDDING_MODEL is set
EMBEDDING_PROVIDER=auto

# Vector Store Configuration
QDRANT_URL=http://qdrant:6333

# OCR Configuration
# OCR_PROVIDER can be: pypdf2, llm
OCR_PROVIDER=llm
# If OCR_PROVIDER=llm, set OCR_LLM_PROVIDER to: openai, anthropic, google, ollama, openai_like
OCR_LLM_PROVIDER=openai

# Parallel Processing Configuration
# Enable parallel processing for faster document processing with OpenAI
OCR_PARALLEL=true
DOCUMENTS_PARALLEL=true
OCR_MAX_CONCURRENCY=5
DOCUMENTS_MAX_CONCURRENCY=3
OCR_MAX_RETRIES=3
DOCUMENTS_MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=text

# CloudWatch Logging (optional, AWS only)
CLOUDWATCH_LOGGING_ENABLED=false
CLOUDWATCH_LOG_GROUP=/chatbot/backend
CLOUDWATCH_LOG_STREAM=backend

# Datadog Monitoring (optional)
DATADOG_API_KEY=
SERVICE_NAME=chatbot-backend

# Sentry Error Tracking (optional)
SENTRY_DSN=
