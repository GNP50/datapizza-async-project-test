    {
      "name": "Test Scenarios",
      "item": [
        {
          "name": "Complete Workflow",
          "item": [
            {
              "name": "1. Register",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                      "const response = pm.response.json();",
                      "if (response.access_token) {",
                      "    pm.collectionVariables.set('access_token', response.access_token);",
                      "    pm.collectionVariables.set('refresh_token', response.refresh_token);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"workflow@example.com\",\n  \"password\": \"Password123!\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/auth/register",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "auth", "register"]
                }
              }
            },
            {
              "name": "2. Create Chat + Message",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Message sent', () => pm.response.to.have.status(201));",
                      "const response = pm.response.json();",
                      "pm.collectionVariables.set('message_id', response.id);",
                      "pm.collectionVariables.set('chat_id', response.chat_id);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {"key": "Authorization", "value": "Bearer {{access_token}}"}
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {"key": "content", "value": "What is the capital of France?", "type": "text"}
                  ]
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/messages",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "messages"]
                }
              }
            },
            {
              "name": "3. Check Status (Wait 2s)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "setTimeout(() => {}, 2000);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status retrieved', () => pm.response.to.have.status(200));",
                      "const response = pm.response.json();",
                      "console.log('Processing state:', response.processing_state);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {"key": "Authorization", "value": "Bearer {{access_token}}"}
                ],
                "url": {
                  "raw": "{{base_url}}/api/v1/messages/{{message_id}}/status",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "messages", "{{message_id}}", "status"]
                }
              }
            },
            {
              "name": "4. Get Messages",
              "request": {
                "method": "GET",
                "header": [
                  {"key": "Authorization", "value": "Bearer {{access_token}}"}
                ],
                "url": {
                  "raw": "{{base_url}}/api/v1/chats/{{chat_id}}/messages",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "chats", "{{chat_id}}", "messages"]
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  }
}
